# ============================================================
# WebMail Backend — Environment Configuration (Updated)
# Salin file ini ke .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke version control!
# ============================================================

# ─── APP ────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=4001
ALLOW_ORIGINS=http://localhost:3000,http://localhost:4000,https://mail.yourdomain.com
LOG_LEVEL=info

# ─── DATABASE (PostgreSQL 16) ────────────────────────────────
DATABASE_URL=postgres://webmail:strongpassword@localhost:5432/webmail?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=5
MIGRATIONS_PATH=file://migrations

# ─── REDIS 7.4 ───────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT_SEC=5
REDIS_READ_TIMEOUT_SEC=3
REDIS_WRITE_TIMEOUT_SEC=3

# ─── JWT ────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_ACCESS_SECRET=GANTI_DENGAN_RANDOM_SECRET_PANJANG_64_KARAKTER
JWT_REFRESH_SECRET=GANTI_DENGAN_RANDOM_SECRET_BERBEDA_64_KARAKTER

JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ─── STALWART IMAP ──────────────────────────────────────────
IMAP_HOST=localhost
IMAP_PORT=993
IMAP_USE_TLS=true
IMAP_POOL_SIZE=5

# ─── STALWART SMTP ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587          # 587=STARTTLS, 465=Implicit TLS
SMTP_USE_TLS=false     # false=STARTTLS (587), true=ImplicitTLS (465)

# ─── JMAP (Opsional) ────────────────────────────────────────
JMAP_ENABLED=false
JMAP_BASE_URL=https://mail.yourdomain.com/jmap

# ─── CRYPTOGRAPHY ───────────────────────────────────────────
# Generate: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=GANTI_DENGAN_64_KARAKTER_HEX_RANDOM_UNTUK_AES256
APP_KEY=GANTI_DENGAN_64_KARAKTER_HEX_RANDOM_UNTUK_APP_KEY

# ─── WEBSOCKET ──────────────────────────────────────────────
# Aktifkan/non-aktifkan WebSocket koneksi
# true = WebSocket diaktifkan, false = WebSocket dinonaktifkan
WEBSOCKET_ENABLED=false

# Interval ping dalam detik (default: 60 = 1 menit)
WEBSOCKET_INTERVAL_SEC=60

# WebSocket tersedia di: ws://<host>:<port>/api/v1/ws?token=<jwt>
# Tidak perlu konfigurasi tambahan — WebSocket menggunakan port yang sama
# dengan HTTP server. Hub dijalankan sebagai goroutine internal.
